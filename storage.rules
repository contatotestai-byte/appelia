rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Cada usuário só acessa seus próprios arquivos, organizados por uid.
    // Estrutura: comprovantes/{uid}/..., nfs/{uid}/..., contratos/{uid}/...
    match /{folder}/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId
                         && (folder == 'comprovantes' || folder == 'nfs' || folder == 'contratos');
    }
  }
}
