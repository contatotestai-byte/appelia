# =====================================================================
# FRONTEND (client) — variáveis públicas do Firebase (prefixo VITE_)
# Estas chaves são públicas por design (Firebase as expõe no client).
# Copie este arquivo para `.env` e preencha com os valores do seu projeto.
# Pegue em: Firebase Console > Configurações do projeto > Seus apps (Web).
# =====================================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloud Messaging — chave VAPID (Web Push certificate)
# Firebase Console > Configurações > Cloud Messaging > Web Push certificates
VITE_FIREBASE_VAPID_KEY=

# (Opcional) usar emuladores locais do Firebase em dev: "true" / "false"
VITE_USE_FIREBASE_EMULATORS=false

# =====================================================================
# CLOUD FUNCTIONS (servidor) — NUNCA expor no client / nunca commitar.
# Defina via:  firebase functions:config  OU  functions/.env
# =====================================================================
# Provedor de IA: "gemini" (gratuito) ou "claude" (pago)
AI_PROVIDER=gemini
# Chave do Google AI Studio (Gemini) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Chave Anthropic (Claude) — usada apenas se AI_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Integrações externas (stubs por enquanto; preencher quando ligar) ---
# Google Vision (OCR)
GOOGLE_VISION_API_KEY=
# WhatsApp — Z-API
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
# WhatsApp — Twilio (alternativa)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Google Calendar (OAuth)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# Meta Marketing API
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# Feed de notícias (ex.: NewsAPI) — opcional
NEWS_API_KEY=
